# Multi-stage Dockerfile for Astra Framework Applications
FROM golang:1.21-alpine AS builder

# Install build dependencies
RUN apk add --no-cache gcc musl-dev

WORKDIR /app

# Download dependencies
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Build the application with production flags
# -ldflags="-w -s" reduces binary size
# -trimpath removes absolute paths from the binary
RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags="-w -s" \
    -trimpath \
    -o main ./cmd/main.go

# Production stage - use a small, secure base image
FROM alpine:latest
RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app

# Copy the binary from the builder
COPY --from=builder /app/main .

# Copy environment example and config
COPY --from=builder /app/.env.example ./.env

# Copy resources (templates, etc.) and public assets
COPY --from=builder /app/resources ./resources
COPY --from=builder /app/public ./public

# Create storage directory for local driver
RUN mkdir -p storage/logs

# Set default environment variables
ENV APP_ENV=production
ENV PORT=3333

EXPOSE 3333

# Run the application
CMD ["./main"]
