APP_NAME={{.AppName}}
APP_ENV=development
APP_KEY={{.AppKey}}
APP_DEBUG=true
PORT=3333
HOST=0.0.0.0

# Database
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/{{.AppName}}?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_MAX_IDLE=30s
DB_SSL=disable

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Auth
JWT_SECRET={{.JWTSecret}}
JWT_ISSUER=astra
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Services
MAIL_DRIVER=log
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./storage

# Queue
QUEUE_DRIVER=redis
QUEUE_CONCURRENCY=5
QUEUE_PREFIX=astra:queue:

# Observability (OpenTelemetry)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME={{.AppName}}

# WebSockets
WS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
