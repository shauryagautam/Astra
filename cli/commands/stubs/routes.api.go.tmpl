package routes

import (
	"github.com/astraframework/astra/http"
)

func Register(r *http.Router) {
	// Apply secure headers by default
	r.Use(http.SecureHeaders({{.SecurityConfig}}))

	r.Get("/health", http.HealthHandler())
	r.Get("/ready", http.ReadyHandler())

	// Add your routes here
	// r.Get("/", "HomeController@Index")
}
